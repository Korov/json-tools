{
    "name": "json-tools-z",
    "publisher": "korov",
    "displayName": "JSON Tools z",
    "description": "Format and minify JSON or JSON5 while preserving large integer values",
    "version": "0.0.6",
    "license": "Apache-2.0",
    "icon": "images/icon.png",
    "keywords": [
        "json",
        "json5",
        "formatter",
        "minify",
        "bigint",
        "large-integers",
        "safe-integer",
        "vscode-extension"
    ],
    "homepage": "https://github.com/Korov/json-tools#readme",
    "bugs": {
        "url": "https://github.com/Korov/json-tools/issues"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/korov/json-tools.git"
    },
    "engines": {
        "vscode": "^1.96.0"
    },
    "categories": [
        "Formatters",
        "Other"
    ],
    "activationEvents": [],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "json-tools.pretty",
                "title": "JSON Tools: Pretty Print"
            },
            {
                "command": "json-tools.minify",
                "title": "JSON Tools: Minify"
            }
        ],
        "menus": {
            "editor/context": [
                {
                    "command": "json-tools.pretty",
                    "group": "1_modification"
                },
                {
                    "command": "json-tools.minify",
                    "group": "1_modification"
                }
            ]
        },
        "keybindings": [
            {
                "command": "json-tools.pretty",
                "key": "ctrl+alt+m",
                "mac": "cmd+alt+m"
            },
            {
                "command": "json-tools.minify",
                "key": "alt+m"
            }
        ],
        "configuration": {
            "title": "JSON Tools",
            "properties": {
                "jsonTools.indentSize": {
                    "type": "number",
                    "default": 4,
                    "minimum": 1,
                    "maximum": 8,
                    "description": "Number of spaces used by the pretty print command."
                },
                "jsonTools.preserveLargeIntegers": {
                    "type": "boolean",
                    "default": true,
                    "description": "Preserve integer literals outside JavaScript's safe integer range while formatting or minifying JSON."
                },
                "jsonTools.insertFinalNewline": {
                    "type": "boolean",
                    "default": false,
                    "description": "Insert a final newline after formatting or minifying JSON."
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "generate:icon": "node scripts/generate-icon.js",
        "test": "npm run compile && node --test test/*.test.js",
        "watch": "tsc -watch -p ./"
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "@types/vscode": "^1.96.0",
        "typescript": "^5.0.0"
    },
    "dependencies": {
        "json5": "^2.2.3"
    }
}